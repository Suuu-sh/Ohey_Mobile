# Ohey environment variables
# Local defaults target dev-ohey and the dev Render backend.
OHEY_ENV=dev
SUPABASE_URL=https://wwyaftonswgxnjcceyfb.supabase.co
SUPABASE_PUBLISHABLE_KEY=replace_with_publishable_key
SUPABASE_AUTH_REDIRECT_URL=app.ohey.com.dev://login-callback/

# Go backend for app data. Auth remains direct Supabase Auth.
# iOS Simulator / dev checks should use Render dev, not localhost.
OHEY_BACKEND_URL=https://dev-ohey-backend.onrender.com

# Comma-separated admin account emails for Mobile-only UI checks.
OHEY_ADMIN_EMAILS=

# AdMob production IDs. Debug/Profile builds use Google test IDs; Release builds
# disable ads unless these are set to non-sample production values.
OHEY_ADMOB_IOS_APP_ID=
OHEY_ADMOB_ANDROID_APP_ID=
OHEY_ADMOB_IOS_NATIVE_AD_UNIT_ID=
OHEY_ADMOB_ANDROID_NATIVE_AD_UNIT_ID=

# Legal document URLs used by profile/settings links.
OHEY_TERMS_URL=https://pwifgddolctqghygwxwj.supabase.co/storage/v1/object/public/legal/terms.txt
OHEY_PRIVACY_URL=https://pwifgddolctqghygwxwj.supabase.co/storage/v1/object/public/legal/privacy-policy.txt
