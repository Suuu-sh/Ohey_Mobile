# Ohey environment variables
# Local defaults target the dev Render backend.
OHEY_ENV=dev
CLERK_PUBLISHABLE_KEY=replace_with_clerk_publishable_key
CLERK_JWT_TEMPLATE=ohey-mobile
OHEY_AUTH_REDIRECT_URL=app.ohey.com.dev://login-callback/

# Go backend for app data.
# iOS Simulator / dev checks should use Render dev, not localhost.
OHEY_BACKEND_URL=https://dev-ohey-backend.onrender.com

OHEY_SUPPORT_EMAIL=support@oheyapp.com

# AdMob production IDs. Debug/Profile builds use Google test IDs; Release builds
# disable ads unless these are set to non-sample production values.
OHEY_ADMOB_IOS_APP_ID=
OHEY_ADMOB_ANDROID_APP_ID=
OHEY_ADMOB_IOS_NATIVE_AD_UNIT_ID=
OHEY_ADMOB_ANDROID_NATIVE_AD_UNIT_ID=

# Legal document URLs. Defaults are served by the backend when omitted.
OHEY_TERMS_URL=
OHEY_PRIVACY_URL=
# RevenueCat / Ohey Plus. Use the iOS public SDK key from RevenueCat.
# Product/entitlement/offering IDs must match RevenueCat and App Store Connect.
OHEY_REVENUECAT_IOS_API_KEY=
OHEY_REVENUECAT_ENTITLEMENT_ID=plus
OHEY_REVENUECAT_OFFERING_ID=default
OHEY_REVENUECAT_PRODUCT_ID=ohey_plus_monthly
