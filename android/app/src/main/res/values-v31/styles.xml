<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowSplashScreenBackground">#FF0A8D</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/opening_tomo_splash_icon</item>
        <item name="android:windowSplashScreenAnimationDuration">0</item>
        <item name="android:windowSplashScreenIconBackgroundColor">#00000000</item>
        <item name="android:postSplashScreenTheme">@style/NormalTheme</item>
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>

    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">#FF0A8D</item>
    </style>
</resources>
